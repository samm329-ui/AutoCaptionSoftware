{"index": 0, "lang": "hindi", "raw": "\u0939\u0947 \u092e\u0928\u094b\u091c \u092a\u0941\u0924\u094d\u0930 \u0915\u094c\u0938\u094d\u0924\u094b\u092c, \u0939\u092e \u0906\u092a\u0915\u094b \u0928\u0917\u0930 \u0915\u0940 \u092f\u093e\u0924\u094d\u0930\u093e \u092e\u0947\u0902 \u091a\u0932\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0906\u092e\u0902\u0924\u093f\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902, \u0915\u0943\u092a\u092f\u093e \u0915\u0930\u0915\u0947 \u0906\u092a \u091c\u0932\u094d\u0926\u0940 \u092c\u093e\u0939\u0930 \u0906\u090f\u0902 \u0905\u092d\u0940 \u092a\u094d\u0930\u0924\u093f\u0915\u094d\u0937\u093e \u0915\u0930\u093f\u092f\u0947 \u092e\u093f\u0924\u094d\u0930, \u0905\u092d\u0940 \u0939\u092e \u0928\u093f\u0930\u094d\u0935\u0938\u094d\u0924 \u0930\u0939\u0947 \u0939\u0948\u0902, \u0939\u092e \u0938\u0940\u0916\u0930 \u0939\u0940 \u0906\u092a\u0915\u0947 \u092a\u093e\u0938 \u0906\u0924\u0947 \u0939\u0948\u0902 \u0920\u0940\u0915 \u0939\u0948 \u092e\u093f\u0924\u094d\u0930 \u0924\u092c \u0924\u0915 \u0906\u092a \u0939\u092e\u0947\u0902 \u0905\u092a\u0928\u0947 \u0926\u094b \u091a\u0915\u094d\u0915\u093e", "refined": "\u0939\u0947 \u092e\u0928\u094b\u091c \u092a\u0941\u0924\u094d\u0930 \u0915\u094c\u0938\u094d\u0924\u094b\u092c, \u0939\u092e \u0906\u092a\u0915\u094b \u0928\u0917\u0930 \u0915\u0940 \u092f\u093e\u0924\u094d\u0930\u093e \u092e\u0947\u0902 \u091a\u0932\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0906\u092e\u0902\u0924\u094d\u0930\u093f\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902, \u0915\u0943\u092a\u092f\u093e \u0915\u0930\u0915\u0947 \u0906\u092a \u091c\u0932\u094d\u0926\u0940 \u092c\u093e\u0939\u0930 \u0906\u090f\u0902\u0964 \u0905\u092d\u0940 \u092a\u094d\u0930\u0924\u0940\u0915\u094d\u0937\u093e \u0915\u0940\u091c\u093f\u090f, \u092e\u093f\u0924\u094d\u0930, \u0905\u092d\u0940 \u0939\u092e \u0924\u0948\u092f\u093e\u0930 \u0939\u094b \u0930\u0939\u0947 \u0939\u0948\u0902\u0964 \u0939\u092e \u0936\u0940\u0918\u094d\u0930 \u0939\u0940 \u0906\u092a\u0915\u0947 \u092a\u093e\u0938 \u0906\u0924\u0947 \u0939\u0948\u0902\u0964 \u0920\u0940\u0915 \u0939\u0948, \u092e\u093f\u0924\u094d\u0930\u0964 \u0924\u092c \u0924\u0915 \u0906\u092a \u0939\u092e\u0947\u0902 \u0905\u092a\u0928\u0947 \u0926\u094b\u092a\u0939\u093f\u092f\u093e \u0935\u093e\u0939\u0928 \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u092c\u0924\u093e\u090f\u0902\u0964", "final": "\u0939\u0947 \u092e\u0928\u094b\u091c \u092a\u0941\u0924\u094d\u0930 \u0915\u094c\u0938\u094d\u0924\u094b\u092c, \u0939\u092e \u0906\u092a\u0915\u094b \u0928\u0917\u0930 \u0915\u0940 \u092f\u093e\u0924\u094d\u0930\u093e \u092e\u0947\u0902 \u091a\u0932\u0928\u0947 \u0915\u0947 \u0932\u093f\u090f \u0906\u092e\u0902\u0924\u094d\u0930\u093f\u0924 \u0915\u0930\u0924\u0947 \u0939\u0948\u0902, \u0915\u0943\u092a\u092f\u093e \u0915\u0930\u0915\u0947 \u0906\u092a \u091c\u0932\u094d\u0926\u0940 \u092c\u093e\u0939\u0930 \u0906\u090f\u0902\u0964 \u0905\u092d\u0940 \u092a\u094d\u0930\u0924\u0940\u0915\u094d\u0937\u093e \u0915\u0940\u091c\u093f\u090f, \u092e\u093f\u0924\u094d\u0930, \u0905\u092d\u0940 \u0939\u092e \u0924\u0948\u092f\u093e\u0930 \u0939\u094b \u0930\u0939\u0947 \u0939\u0948\u0902\u0964 \u0939\u092e \u0936\u0940\u0918\u094d\u0930 \u0939\u0940 \u0906\u092a\u0915\u0947 \u092a\u093e\u0938 \u0906\u0924\u0947 \u0939\u0948\u0902\u0964 \u0920\u0940\u0915 \u0939\u0948, \u092e\u093f\u0924\u094d\u0930\u0964 \u0924\u092c \u0924\u0915 \u0906\u092a \u0939\u092e\u0947\u0902 \u0905\u092a\u0928\u0947 \u0926\u094b\u092a\u0939\u093f\u092f\u093e \u0935\u093e\u0939\u0928 \u0915\u0947 \u092c\u093e\u0930\u0947 \u092e\u0947\u0902 \u092c\u0924\u093e\u090f\u0902\u0964", "score": 0.8924957524175229}
{"index": 1, "lang": "hindi", "raw": "\u0920\u0940\u0915 \u0939\u0948 \u092e\u093f\u0924\u094d\u0930, \u0924\u092c \u0924\u0915 \u0906\u092a \u0939\u092e\u0947\u0902 \u0905\u092a\u0928\u0947 \u0926\u094b \u091a\u0915\u094d\u0930\u093f\u0915\u093e \u0935\u0939\u0928 \u0915\u0940 \u0915\u0941\u0902\u091c\u0940, \u0938\u093e\u0924\u0940 \u0906\u092f\u0947 \u0938\u093e\u0907\u092c \u092a\u094d\u0930\u092e\u093e\u0921\u093f\u0924 \u092e\u0941\u0917\u0941\u091f \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0947\u0902\u0964 \u0906\u092a \u0907\u0938 \u092c\u093e\u0924 \u0938\u0947 \u092d\u0932\u0940 \u092c\u093e\u0924\u0940 \u0905\u0909\u0917\u0924 \u0939\u094b\u0902\u0917\u0947 \u0915\u093f \u0939\u092e\u093e\u0930\u0947 \u0928\u0917\u0930 \u0915\u0940 \u092f\u093e\u0924\u093e \u092f\u093e\u0924 \u0938\u0947\u0928\u093e \u091a\u093e\u0932\u093e\u0928 \u0915\u0930\u0928\u0947 \u092e\u0947\u0902 \u0906\u0924\u0942\u0930 \u0939\u0948\u0964 \u091c\u094b \u0906\u0917\u094d\u092f\u093e \u092e\u093f\u0924\u094d\u0930\u0964", "refined": "\u0920\u0940\u0915 \u0939\u0948 \u092e\u093f\u0924\u094d\u0930, \u0924\u092c \u0924\u0915 \u0906\u092a \u0939\u092e\u0947\u0902 \u0905\u092a\u0928\u0947 \u0926\u094b \u091a\u0915\u094d\u0930\u093f\u0915\u093e \u0935\u0939\u0928 \u0915\u0940 \u0915\u0941\u0902\u091c\u0940, \u0938\u093e\u0924\u0940 \u0906\u092f\u0947 \u0938\u093e\u0907\u092c \u092a\u094d\u0930\u092e\u093e\u0926\u093f\u0924 \u092e\u0941\u0915\u0941\u091f \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0947\u0902\u0964 \u0906\u092a \u0907\u0938 \u092c\u093e\u0924 \u0938\u0947 \u092d\u0932\u0940 \u092d\u093e\u0902\u0924\u093f \u0905\u0935\u0917\u0924 \u0939\u094b\u0902\u0917\u0947 \u0915\u093f \u0939\u092e\u093e\u0930\u0947 \u0928\u0917\u0930 \u0915\u0940 \u092f\u093e\u0924\u093e\u092f\u093e\u0924 \u0938\u0947\u0928\u093e \u091a\u093e\u0932\u093e\u0928 \u0915\u0930\u0928\u0947 \u092e\u0947\u0902 \u0906\u0924\u0941\u0930 \u0939\u0948\u0964 \u091c\u094b \u0906\u091c\u094d\u091e\u093e \u092e\u093f\u0924\u094d\u0930\u0964", "final": "\u0920\u0940\u0915 \u0939\u0948 \u092e\u093f\u0924\u094d\u0930, \u0924\u092c \u0924\u0915 \u0906\u092a \u0939\u092e\u0947\u0902 \u0905\u092a\u0928\u0947 \u0926\u094b \u091a\u0915\u094d\u0930\u093f\u0915\u093e \u0935\u0939\u0928 \u0915\u0940 \u0915\u0941\u0902\u091c\u0940, \u0938\u093e\u0924\u0940 \u0906\u092f\u0947 \u0938\u093e\u0907\u092c \u092a\u094d\u0930\u092e\u093e\u0926\u093f\u0924 \u092e\u0941\u0915\u0941\u091f \u092a\u094d\u0930\u0926\u093e\u0928 \u0915\u0930\u0947\u0902\u0964 \u0906\u092a \u0907\u0938 \u092c\u093e\u0924 \u0938\u0947 \u092d\u0932\u0940 \u092d\u093e\u0902\u0924\u093f \u0905\u0935\u0917\u0924 \u0939\u094b\u0902\u0917\u0947 \u0915\u093f \u0939\u092e\u093e\u0930\u0947 \u0928\u0917\u0930 \u0915\u0940 \u092f\u093e\u0924\u093e\u092f\u093e\u0924 \u0938\u0947\u0928\u093e \u091a\u093e\u0932\u093e\u0928 \u0915\u0930\u0928\u0947 \u092e\u0947\u0902 \u0906\u0924\u0941\u0930 \u0939\u0948\u0964 \u091c\u094b \u0906\u091c\u094d\u091e\u093e \u092e\u093f\u0924\u094d\u0930\u0964", "score": 0.8397403423379106}
{"index": 2, "lang": "hindi", "raw": "\u091c\u094b \u0906\u0917\u094d\u092f\u093e \u092e\u093f\u0924\u094d\u0930, \u0930\u0926\u093f\u0936\u093e \u0915\u0930\u093f\u092f\u0947\u0964 \u092e\u093f\u0924\u094d\u0930, \u0905\u092a\u0928\u093e \u0935\u0939\u093e\u0928 \u0938\u094d\u0935\u092f\u0902 \u091a\u0932\u093e\u090f, \u0939\u092e \u0906\u091c \u091a\u093e\u0932\u093e \u0905\u0928\u0941\u0917\u092f \u092a\u094d\u0932\u093e\u0928\u093e \u092d\u0942\u0932 \u0917\u090f\u0964 \u0939\u092e \u0938\u094d\u0935\u092f\u0902 \u0938\u0902\u0915\u091f \u092e\u0947\u0902 \u0939\u0948\u0902 \u092e\u093f\u0924\u094d\u0930, \u0915\u094d\u092f\u094b\u0902\u0915\u093f \u0939\u092e\u093e\u0930\u0947 \u0915\u0926\u092e \u092a\u094d\u0930\u0924\u094d\u0935\u0940 \u0924\u0915 \u0928\u0939\u0940\u0902 \u092a\u0939\u0941\u0901\u091a\u0924\u0947 \u0939\u0948\u0902, \u0914\u0930 \u0935\u0939\u093e\u0928...", "refined": "\u091c\u094b \u0906\u0917\u094d\u092f\u093e \u092e\u093f\u0924\u094d\u0930, \u0930\u0941\u0915\u093f\u0936\u093e \u0915\u0930\u093f\u090f\u0964 \u092e\u093f\u0924\u094d\u0930, \u0905\u092a\u0928\u093e \u0935\u093e\u0939\u0928 \u0938\u094d\u0935\u092f\u0902 \u091a\u0932\u093e\u090f, \u0939\u092e \u0906\u091c \u091a\u0932\u0928\u0947 \u0915\u093e \u092a\u094d\u0932\u093e\u0928 \u092d\u0942\u0932 \u0917\u090f\u0964 \u0939\u092e \u0938\u094d\u0935\u092f\u0902 \u0938\u0902\u0915\u091f \u092e\u0947\u0902 \u0939\u0948\u0902 \u092e\u093f\u0924\u094d\u0930, \u0915\u094d\u092f\u094b\u0902\u0915\u093f \u0939\u092e\u093e\u0930\u0947 \u092a\u0948\u0930 \u091c\u092e\u0940\u0928 \u0924\u0915 \u0928\u0939\u0940\u0902 \u092a\u0939\u0941\u0901\u091a\u0924\u0947 \u0939\u0948\u0902, \u0914\u0930 \u0935\u093e\u0939\u0928...", "final": "\u091c\u094b \u0906\u0917\u094d\u092f\u093e \u092e\u093f\u0924\u094d\u0930, \u0930\u0941\u0915\u093f\u0936\u093e \u0915\u0930\u093f\u090f\u0964 \u092e\u093f\u0924\u094d\u0930, \u0905\u092a\u0928\u093e \u0935\u093e\u0939\u0928 \u0938\u094d\u0935\u092f\u0902 \u091a\