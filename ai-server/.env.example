# ─── CaptionAI Pro — Environment Configuration ────────────────────────────────

# FFmpeg binary directory (OPTIONAL)
# Leave blank if ffmpeg is already in your system PATH.
# Windows example:
#   FFMPEG_BIN=C:\ffmpeg\bin
# Linux/Mac: leave blank if installed via apt/brew
FFMPEG_BIN=

# Whisper model size: tiny | base | small | medium | large
# Larger = more accurate but slower and uses more RAM/VRAM
# Recommended: base (fast) or small (balanced)
WHISPER_MODEL=base

# Server port
PORT=8000

# ─── DO NOT hardcode ffmpeg paths inside .py files ─────────────────────────────
# Set the path here once, and all modules will pick it up automatically.
