# CaptionAI Pro - Environment Variables
# Copy this file to .env and fill in your values

# Optional: Supabase credentials (for cloud storage - not required for local mode)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-key

# Optional: API Keys for translation services
# GOOGLE_TRANSLATE_API_KEY=your-google-api-key

# Optional: GPU Settings (auto-detected, but can be overridden)
# CUDA_VISIBLE_DEVICES=0

# Whisper Model Size: tiny, base, small, medium, large-v2, large-v3
# WHISPER_MODEL=base

# Compute Type: int8 (CPU), float16 (GPU), float32
# COMPUTE_TYPE=float16

# Batch Size: 4 (CPU), 16 (GPU)
# BATCH_SIZE=16

# Server Port (default: 8000)
# PORT=8000
